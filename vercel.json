{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/lesson-v2", "destination": "/api/lesson-v2" },
    { "source": "/api/questoes-ai", "destination": "/api/questoes-ai" },
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "crons": [
    {
      "path": "/api/supabase/keep-alive",
      "schedule": "0 6 * * *"
    }
  ]
}
