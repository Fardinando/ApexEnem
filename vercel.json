{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/lesson-v2", "dest": "/api/lesson-v2.ts" },
    { "src": "/api/questoes-ai", "dest": "/api/questoes-ai.ts" },
    { "src": "/api/(.*)", "dest": "/api" }
  ],
  "crons": [
    {
      "path": "/api/supabase/keep-alive",
      "schedule": "0 6 * * *"
    }
  ]
}
