{
  "buildCommand": "vite build && esbuild server.ts --bundle --platform=node --target=node18 --packages=external --format=esm --outfile=dist/api/index.js",
  "outputDirectory": "dist",
  "devCommand": "tsx server.ts",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/supabase/keep-alive",
      "schedule": "0 6 * * *"
    }
  ]
}
