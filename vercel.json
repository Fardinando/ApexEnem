{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/stats", "destination": "/api" },
    { "source": "/api/correct", "destination": "/api" },
    { "source": "/api/questions", "destination": "/api" },
    { "source": "/api/questions/status/(.*)", "destination": "/api" },
    { "source": "/api/delete-account", "destination": "/api" },
    { "source": "/api/credentials-status", "destination": "/api" },
    { "source": "/api/supabase/(.*)", "destination": "/api" },
    { "source": "/api/auth/(.*)", "destination": "/api" },
    { "source": "/api/gamification/(.*)", "destination": "/api" },
    { "source": "/api/streak/(.*)", "destination": "/api" },
    { "source": "/api/weekly-ranking", "destination": "/api" },
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "crons": [
    {
      "path": "/api/supabase/keep-alive",
      "schedule": "0 6 * * *"
    }
  ]
}
