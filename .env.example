# ═══════════════════════════════════════════
#  VARIÁVEIS OBRIGATÓRIAS
# ═══════════════════════════════════════════

# OPENROUTER_API_KEY (backend)
# OBRIGATÓRIA para correção de redação por IAs e perguntas.
# Crie conta grátis: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# VITE_GOOGLE_API_KEY (frontend)
# Necessária para chamadas diretas de Gemini no browser (aulas e questões).
VITE_GOOGLE_API_KEY="AIza..."

# SUPABASE_URL (backend)
# OBRIGATÓRIA para autenticação e banco de dados.
# Obtenha em: Supabase Dashboard > Project Settings > API
SUPABASE_URL="https://seu-projeto.supabase.co"

# SUPABASE_ANON_KEY (backend)
# OBRIGATÓRIA - chave anônima (pública) do Supabase.
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIs..."

# VITE_SUPABASE_URL (frontend)
# OBRIGATÓRIA - mesma URL do SUPABASE_URL, mas com prefixo VITE_ para o Vite.
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"

# VITE_SUPABASE_ANON_KEY (frontend)
# OBRIGATÓRIA - mesma chave do SUPABASE_ANON_KEY, com prefixo VITE_.
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIs..."

# ═══════════════════════════════════════════
#  VARIÁVEIS OPCIONAIS
# ═══════════════════════════════════════════

# SUPABASE_SERVICE_ROLE_KEY
# OPCIONAL - necessária apenas para setup automático de tabelas via backend.
# CUIDADO: essa chave tem acesso total ao banco.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIs..."

# VITE_HCAPTCHA_SITE_KEY
# OPCIONAL - obrigatória apenas se você ativou hCaptcha no Supabase.
# Para ativar: Supabase Dashboard > Authentication > Security > Bot Detection
# Site key gerada em: https://www.hcaptcha.com/
VITE_HCAPTCHA_SITE_KEY="sua-hcaptcha-site-key"

# HMAC_SECRET
# OBRIGATÓRIA - segredo para assinar tokens de confirmação no backend.
# Gere uma string aleatória forte (ex: openssl rand -hex 32)
HMAC_SECRET="sua-chave-secreta-aqui"

# ALLOWED_ORIGINS
# OPCIONAL - origens permitidas no CORS (separadas por vírgula).
# Se não definido, permite apenas localhost:5173 e localhost:3000.
# Ex: "https://apexenem.vercel.app,https://meudominio.com"
ALLOWED_ORIGINS="https://apexenem.vercel.app"

# ═══════════════════════════════════════════
#  APEXGUARDIAN (Reporte de Erros)
# ═══════════════════════════════════════════
# URL do ApexGuardian para reporte de erros.
# OPCIONAL - se não definido, o botão "Reportar Erro" usará o fallback.
VITE_APEXGUARDIAN_URL="https://apexguardian.onrender.com"

# ═══════════════════════════════════════════
#  ANÚNCIOS
# ═══════════════════════════════════════════
# Para configurar anúncios (Adsterra, PropellerAds, etc.):
# Edite o arquivo src/config/ads.ts e cole o código HTML/JS de cada slot.
# Suporta: banners, popunders, nativos, etc.
