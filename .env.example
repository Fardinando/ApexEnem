# OPENROUTER_API_KEY: Chave de API do OpenRouter para usar modelos gratuitos.
# Crie uma conta em https://openrouter.ai, vá em Keys e gere uma chave.
# Modelos gratuitos disponíveis: meta-llama/llama-3.3-70b-instruct:free,
# deepseek/deepseek-r1:free, qwen/qwen-2.5-72b-instruct:free, e muitos outros.
# SEM ESTA CHAVE, as funcionalidades de IA (correção de redação, perguntas, chat) não funcionarão.
OPENROUTER_API_KEY=""

# SUPABASE_URL & SUPABASE_ANON_KEY: Credenciais opcionais para salvar progresso na nuvem.
# Se não configurado, o progresso é salvo apenas localmente (navegador).
# Obtenha em: Supabase Dashboard > Settings > API
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIs..."

# SUPABASE_SERVICE_ROLE_KEY: Necessário apenas para o setup automático da tabela.
# CUIDADO: Essa chave tem acesso total ao banco. Use apenas no servidor, nunca no frontend.
# Obtenha em: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIs..."

# OPENROUTER_API_KEY: OBRIGATÓRIO para as funcionalidades de IA.
# Crie uma conta grátis em https://openrouter.ai/keys e gere uma chave.
# Modelos gratuitos disponíveis: meta-llama/llama-3.3-70b-instruct:free,
# deepseek/deepseek-r1:free, qwen/qwen-2.5-72b-instruct:free, e outros.
OPENROUTER_API_KEY="sk-or-v1-..."
