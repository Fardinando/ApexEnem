# SUPABASE_URL (backend): URL do seu projeto Supabase
# SUPABASE_ANON_KEY (backend): Chave anônima (pública) do Supabase
# VITE_SUPABASE_URL (frontend): Mesma URL do SUPABASE_URL
# VITE_SUPABASE_ANON_KEY (frontend): Mesma chave do SUPABASE_ANON_KEY
# Obtenha em: Supabase Dashboard > Project Settings > API
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIs..."
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIs..."

# SUPABASE_SERVICE_ROLE_KEY: OPCIONAL - necessário apenas para setup automático de tabelas.
# CUIDADO: Essa chave tem acesso total ao banco. Use apenas no servidor, nunca no frontend.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIs..."

# OPENROUTER_API_KEY: OBRIGATÓRIO para funcionalidades de IA (correção de redação, perguntas).
# Crie uma conta grátis em https://openrouter.ai/keys e gere uma chave.
OPENROUTER_API_KEY="sk-or-v1-..."

# RESEND_API_KEY: OPCIONAL - para envio de e-mails via SMTP próprio (Resend).
# Sem esta chave, o Supabase Auth envia os e-mails de confirmação automaticamente.
# Só precisa se quiser usar domínio próprio (ex: contato@apexenem.com.br).
RESEND_API_KEY="re_..."

# EMAIL_FROM: OPCIONAL - endereço de remetente para e-mails de confirmação via Resend.
# Ex: "ApexEnem <noreply@seudominio.com>"
EMAIL_FROM="ApexEnem <noreply@seudominio.com>"

# VITE_HCAPTCHA_SITE_KEY: OPCIONAL - site key do hCaptcha para proteção contra bots.
# Se você ativou hCaptcha no Supabase (Authentication > Security > Bot Detection),
# crie um site key em https://www.hcaptcha.com/ e coloque aqui.
# Se não configurado, o captcha não aparece.
VITE_HCAPTCHA_SITE_KEY="sua-hcaptcha-site-key"

# HMAC_SECRET: OPCIONAL - segredo para assinar tokens de confirmação de e-mail.
# Se não definido, usa OPENROUTER_API_KEY como fallback.
HMAC_SECRET="sua-chave-secreta-aqui"
