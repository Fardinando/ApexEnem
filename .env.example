# OPENROUTER_API_KEY: OBRIGATÓRIO para funcionalidades de IA (correção de redação, perguntas).
# Crie uma conta grátis em https://openrouter.ai/keys e gere uma chave.
OPENROUTER_API_KEY="sk-or-v1-..."

# RESEND_API_KEY: OPCIONAL - para envio real de e-mails de confirmação.
# Crie uma conta em https://resend.com, adicione um domínio e gere uma chave API.
# Sem esta chave, os e-mails são simulados (código exibido na tela).
RESEND_API_KEY="re_..."

# EMAIL_FROM: OPCIONAL - endereço de remetente para e-mails de confirmação.
# Precisa ser de um domínio que você possui e verificou no Resend.
# Ex: "ApexEnem <noreply@seudominio.com.br>"
EMAIL_FROM="ApexEnem <noreply@seudominio.com.br>"

# HMAC_SECRET: OPCIONAL - segredo para assinar tokens de confirmação de e-mail.
# Se não definido, usa OPENROUTER_API_KEY como fallback. Pode ser qualquer string segura.
HMAC_SECRET="sua-chave-secreta-aqui"

# SUPABASE_URL & SUPABASE_ANON_KEY: OPCIONAL - salvar progresso na nuvem via Supabase.
# Sem estas chaves, o progresso é salvo apenas localmente (navegador).
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIs..."

# SUPABASE_SERVICE_ROLE_KEY: OPCIONAL - necessário apenas para setup automático da tabela.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIs..."
